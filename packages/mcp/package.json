{
  "name": "@macrokit/mcp",
  "version": "0.0.1",
  "description": "Minimal public MCP server: expose a Macrokit project's macros + primitives as tools to Claude Code / Cursor, record the session, and let `macrokit gate` flag un-encoded workflows.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && cp src/loader.mjs dist/loader.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@macrokit/runtime": "workspace:*",
    "@macrokit/authoring": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
