{
  "name": "@macrokit/browser",
  "version": "0.0.1",
  "description": "Macrokit browser service: annotated screenshots and DOM action menus for weak LLMs driving web UIs.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "playwright-core": "^1.50.0"
  },
  "peerDependenciesMeta": {
    "playwright-core": { "optional": true }
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "jsdom": "^25.0.1",
    "playwright-core": "^1.50.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
