{
  "name": "@macrokit/runtime",
  "version": "0.0.1",
  "description": "Macrokit runtime: macro registry, dispatcher, session log, router scaffolding.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
